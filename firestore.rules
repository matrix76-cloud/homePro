rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 유저 문서: 본인만 읽기/쓰기
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 전화번호 매핑: 인증된 유저만
    match /phones/{phoneId} {
      allow read, write: if request.auth != null;
    }

    // 오더: 인증된 유저 읽기, 작성자만 쓰기
    match /homepro_orders/{orderId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;
    }

    // 프로 프로필: 인증된 유저 읽기, 본인만 쓰기
    match /homepro_pros/{proId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == proId;
    }

    // 구독: 본인만
    match /homepro_subscriptions/{subId} {
      allow read, write: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // 정산: 본인만 읽기
    match /homepro_settlements/{settleId} {
      allow read: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // 리뷰: 인증된 유저 읽기, 작성자만 쓰기
    match /homepro_reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;
    }

    // 추천인: 인증된 유저
    match /homepro_referrals/{refId} {
      allow read, write: if request.auth != null;
    }

    // 캐시: 본인만
    match /homepro_cash/{cashId} {
      allow read: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow write: if false; // 서버에서만 쓰기
    }

    // 채팅: 참여자만
    match /homepro_chat/{chatId} {
      allow read, write: if request.auth != null;

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
