rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 버전: 누구나 읽기, 쓰기 불가(콘솔/Admin만)
    match /VERSION/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // 관리자: 누구나 읽기(로그인용), 쓰기 불가(콘솔/CF만)
    match /admin/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // 공지: 누구나 읽기, 쓰기 불가(관리자 CF만)
    match /notices/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // 광고: 누구나 읽기
    match /ads/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // 앱 업데이트: 누구나 읽기
    match /app_updates/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // 설정: 누구나 읽기
    match /settings/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // 약관: 누구나 읽기
    match /policies/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // 채팅방 (관리자 조회용)
    match /chatRooms/{roomId} {
      allow read, write: if true;
      match /messages/{msgId} {
        allow read, write: if true;
      }
    }

    // FCM 토큰: 인증된 유저만
    match /fcmTokens/{tokenId} {
      allow read, write: if request.auth != null;
    }

    // 유저 문서: 인증된 유저 읽기/쓰기 (계정 통합 시 다른 문서에 linkedSocialUid 기록 필요)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // 전화번호 매핑: 인증된 유저만
    match /phones/{phoneId} {
      allow read, write: if request.auth != null;
    }

    // 전화번호 → UID 인덱스: 인증된 유저만
    match /users_by_phone/{phoneId} {
      allow read, write: if request.auth != null;
    }

    // 오더: 인증된 유저 읽기, 작성자만 쓰기
    match /homepro_orders/{orderId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;
    }

    // 프로 프로필: 인증된 유저 읽기, 본인 문서만 쓰기/삭제
    match /homepro_pros/{proId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // 구독: 본인만
    match /homepro_subscriptions/{subId} {
      allow read, write: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // 정산: 본인만 읽기
    match /homepro_settlements/{settleId} {
      allow read: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // 리뷰: 인증된 유저 읽기, 작성자만 쓰기
    match /homepro_reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;
    }

    // 추천인: 인증된 유저
    match /homepro_referrals/{refId} {
      allow read, write: if request.auth != null;
    }

    // 캐시: 본인만
    match /homepro_cash/{cashId} {
      allow read: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow write: if false; // 서버에서만 쓰기
    }

    // 채팅: 참여자만
    match /homepro_chat/{chatId} {
      allow read, write: if request.auth != null;

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
